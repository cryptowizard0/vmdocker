VMDOCKER_SCHEDULER=0x972AeD684D6f817e1b58AF70933dF1b4a75bfA51
VMDOCKER_MODULE_ID=4sX9Uo5-Qk37yUOMLCMrwnm4S3Wfu3Fp7QCSRN0oeoU

# Module generation: artifact mode (compile vmdocker_agent locally, then build final image at spawn time without go build)
# VMDOCKER_ARTIFACT_SOURCE_DIR=../../vmdocker_agent
# VMDOCKER_ARTIFACT_GOOS=linux
# VMDOCKER_ARTIFACT_GOARCH=arm64
# VMDOCKER_BUILD_TAG=vmdocker-openclaw:artifact
#
# Module generation: build mode (inline Dockerfile, built at spawn time)
# Set VMDOCKER_BUILD_DOCKERFILE or VMDOCKER_BUILD_DOCKERFILE_PATH to enable build mode; leave both unset for pull mode.
# If VMDOCKER_BUILD_CONTEXT_URL is unset, the local build context directory will be
# compressed into the module tags so spawn can rebuild from module data alone.
# VMDOCKER_BUILD_DOCKERFILE=../../vmdocker_agent/Dockerfile.sandbox
# VMDOCKER_BUILD_CONTEXT_DIR=../../vmdocker_agent
# VMDOCKER_BUILD_DOCKERFILE_PATH=Dockerfile.sandbox
# VMDOCKER_BUILD_CONTEXT_URL=https://github.com/cryptowizard0/vmdocker_agent.git#feature/flow_optimization
# VMDOCKER_BUILD_TAG=vmdocker-openclaw:custom
# VMDOCKER_BUILD_ARG_HTTP_PROXY=http://proxy.example:7890

# Module generation: pull mode (pre-built image from registry)
# VMDOCKER_SANDBOX_IMAGE_NAME=chriswebber/docker-openclaw-sandbox:v0.0.6
# VMDOCKER_SANDBOX_IMAGE_ID=sha256:xxxxxxxx

OPENCLAW_MODULE_ID=AzbJ2MZ7hz5gJnbhWFbQ9JJRRJe4VdVtDAePKUjC6zM
